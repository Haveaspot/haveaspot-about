---
import { Image } from 'astro:assets';
import hb2aImg from '../assets/images/HAS-Bookers-Hero-2a.webp';
import hbVideoImg from '../assets/images/HAS-Bookers-Hero-Video-Panel.webp';
import hb2bImg from '../assets/images/HAS-Bookers-Hero-2b.webp';
---

<!-- Video Lightbox -->
<div id="hb-lightbox" class="hb-lightbox" aria-hidden="true">
	<div class="hb-lightbox-backdrop" id="hb-backdrop"></div>

	<div class="hb-modal">
		<button class="hb-close" id="hb-close" aria-label="Close">
			<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<path d="M18 6 6 18"/><path d="m6 6 12 12"/>
			</svg>
		</button>

		<div class="hb-modal-inner">
			<!-- Video -->
			<div class="hb-video-wrap">
				<div class="hb-video-border"></div>
				<iframe
					id="hb-iframe"
					src=""
					data-src="https://www.youtube.com/embed/F8ppU_i41i4?autoplay=1"
					title="Haveaspot Video"
					frameborder="0"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
					allowfullscreen
				></iframe>
			</div>

			<!-- Side content -->
			<div class="hb-modal-content">
				<h2 class="hb-modal-heading">
					Book A Spot,<br />Support A Spot.
				</h2>
				<p class="hb-modal-body">
					By booking a community spot for your next event, you're giving back and supporting the heart of your neighborhood.
				</p>
				<a href="https://haveaspot.com" class="hb-modal-btn">Book A Spot</a>
			</div>
		</div>
	</div>
</div>

<!-- Hero -->
<section class="hb-hero">
	<div class="hb-container">
		<div class="hb-grid">

			<!-- 1: Text -->
			<div class="hb-text hb-item-1">
				<h1 class="hb-heading">
					Need Space for Anything? Book And Support Your Community Spot.
				</h1>
				<div class="hb-subtext">
					<p class="hb-sub-headline">Do good, book better.</p>
					<p class="hb-description">
						Book community spaces for any activity with Haveaspot! Budget-friendly spots, endless possibilities. Book yours &amp; support your local community!
					</p>
				</div>
				<div class="hb-actions">
					<a href="https://haveaspot.com" class="hb-btn">Book A Spot</a>
				</div>
			</div>

			<!-- 2a: Top right image -->
			<div class="hb-media hb-item-2a">
				<Image src={hb2aImg} alt="Community event at a local space" class="hb-panel-img" loading="eager" />
			</div>

			<!-- 3: Video panel -->
			<div class="hb-media hb-item-3">
				<Image src={hbVideoImg} alt="Person booking a community space" class="hb-panel-img" loading="eager" />

				<div class="hb-video-overlay">
					<div class="hb-find-out">
						<h3 class="hb-find-heading">Find Out More</h3>
						<p class="hb-find-body">
							See how Haveaspot can help put your spot at the heart of your community.
						</p>
					</div>

					<button class="hb-watch-btn" id="hb-open" aria-label="Watch video">
						<span class="hb-watch-label">Watch A Video</span>
					</button>
				</div>
			</div>

			<!-- 2b: Bottom right image -->
			<div class="hb-media hb-item-2b">
				<Image src={hb2bImg} alt="Children's birthday party at a community hall" class="hb-panel-img" loading="eager" />
			</div>

		</div>
	</div>
</section>

<style>
	/* ─── Section ─────────────────────────────────── */
	.hb-hero {
		width: 100%;
		padding: 2rem 0 4rem;
		background-color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 1024px) { .hb-hero { padding: 2rem 0 6rem; } }

	/* ─── Container ──────────────────────────────── */
	.hb-container {
		max-width: 1536px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
	}

	/* ─── Grid ───────────────────────────────────── */
	/*
	  Mobile/tablet: 2 cols, items reordered
	    order 1 — text   (col-span 2)
	    order 2 — video  (col-span 2)
	    order 3 — 2a     (col 1)
	    order 4 — 2b     (col 2)

	  Desktop: 2 cols [3fr 1fr]
	    row 1: text  | 2a
	    row 2: video | 2b
	*/
	.hb-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	@media (min-width: 768px) { .hb-grid { gap: 1.5rem; } }
	@media (min-width: 1024px) {
		.hb-grid {
			grid-template-columns: 3fr 1fr;
			gap: 2rem;
		}
	}

	/* ─── Grid item placement ────────────────────── */
	.hb-item-1 {
		grid-column: 1 / -1;
		order: 1;
	}

	@media (min-width: 1024px) {
		.hb-item-1 { grid-column: 1; grid-row: 1; order: unset; }
	}

	.hb-item-2a {
		grid-column: 1;
		order: 3;
	}

	@media (min-width: 1024px) {
		.hb-item-2a { grid-column: 2; grid-row: 1; order: unset; align-self: stretch; }
	}

	.hb-item-3 {
		grid-column: 1 / -1;
		order: 2;
	}

	@media (min-width: 1024px) {
		.hb-item-3 { grid-column: 1; grid-row: 2; order: unset; }
	}

	.hb-item-2b {
		grid-column: 2;
		order: 4;
	}

	@media (min-width: 1024px) {
		.hb-item-2b { grid-column: 2; grid-row: 2; order: unset; }
	}

	/* ─── Text block ─────────────────────────────── */
	.hb-text {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding-bottom: 1rem;
	}

	@media (min-width: 1024px) { .hb-text { padding-right: 3rem; padding-bottom: 0; } }

	.hb-heading {
		color: #021300;
		font-size: 2.5rem;
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 768px)  { .hb-heading { font-size: 3.75rem; } }
	@media (min-width: 1024px) { .hb-heading { font-size: clamp(3rem, 5vw, 4.75rem); } }

	.hb-subtext {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.hb-sub-headline {
		color: #021300;
		font-size: 1.125rem;
		font-weight: 700;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.hb-description {
		color: #021300;
		font-size: 1rem;
		font-weight: 300;
		line-height: 1.625;
		margin: 0;
		max-width: 48rem;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	/* ─── Button ─────────────────────────────────── */
	.hb-actions { padding-top: 1rem; }

	.hb-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		text-decoration: none;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
	}

	@media (min-width: 640px) { .hb-btn { width: 150px; } }

	.hb-btn:hover {
		background-color: #0AAD0A;
		text-decoration: none;
		color: #ffffff;
	}

	/* ─── Media panels ───────────────────────────── */
	.hb-media {
		border: 2px solid #021300;
		border-radius: 12px;
		overflow: hidden;
		position: relative;
	}

	/* Top right image — stretches to fill row 1 on desktop */
	.hb-item-2a { height: 250px; }
	@media (min-width: 768px)  { .hb-item-2a { height: 300px; } }
	@media (min-width: 1024px) { .hb-item-2a { height: 100%; } }

	/* Video panel heights */
	.hb-item-3 { height: 320px; }
	@media (min-width: 768px)  { .hb-item-3 { height: 380px; } }
	@media (min-width: 1024px) { .hb-item-3 { height: 380px; } }

	/* Bottom right image — matches video panel height */
	.hb-item-2b { height: 250px; }
	@media (min-width: 768px)  { .hb-item-2b { height: 300px; } }
	@media (min-width: 1024px) { .hb-item-2b { height: 380px; } }

	/* Placeholder fills panel until asset is added */
	.hb-placeholder {
		position: absolute;
		inset: 0;
	}

	/* Full-cover image for media panels */
	.hb-panel-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}

	/* ─── Video panel overlay ────────────────────── */
	.hb-video-overlay {
		position: absolute;
		inset: 0;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		gap: 1.5rem;
		z-index: 10;
	}

	@media (min-width: 640px) {
		.hb-video-overlay {
			flex-direction: row;
			align-items: flex-end;
			justify-content: space-between;
			padding: 2rem;
		}
	}

	.hb-find-out {
		background-color: rgba(2, 19, 0, 0.75);
		border-radius: 6px;
		padding: 0.75rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		max-width: 28rem;
	}

	@media (min-width: 640px) { .hb-find-out { padding: 1.5rem; background-color: #021300; } }

	.hb-find-heading {
		color: #ffffff;
		font-size: 1rem;
		font-weight: 700;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 640px) { .hb-find-heading { font-size: 1.5rem; } }

	.hb-find-body {
		color: #ffffff;
		font-size: 0.8125rem;
		font-weight: 400;
		line-height: 1.4;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 640px) { .hb-find-body { font-size: 1rem; line-height: 1.5; } }

	/* ─── Watch Video button ─────────────────────── */
	.hb-watch-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		background-color: #021300;
		border: none;
		border-radius: 6px;
		height: 44px;
		padding: 0 1.25rem;
		color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
		cursor: pointer;
		transition: background-color 0.2s ease;
		width: 100%;
		flex-shrink: 0;
		box-sizing: border-box;
	}

	@media (min-width: 640px) { .hb-watch-btn { width: 150px; } }

	.hb-watch-btn:hover { background-color: #0AAD0A; }

	.hb-watch-label {
		font-size: 16px;
		font-weight: 500;
		white-space: nowrap;
	}

	.hb-watch-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.hb-watch-icon svg { color: #ffffff; }

	/* ─── Lightbox ───────────────────────────────── */
	.hb-lightbox {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 200;
		align-items: center;
		justify-content: center;
		padding: 1rem;
	}

	.hb-lightbox.is-open { display: flex; }

	.hb-lightbox-backdrop {
		position: absolute;
		inset: 0;
		background-color: rgba(0, 0, 0, 0.9);
		backdrop-filter: blur(4px);
	}

	.hb-modal {
		position: relative;
		z-index: 10;
		background-color: #ffffff;
		border: 2px solid #021300;
		border-radius: 12px;
		padding: 4.5rem 2rem 2rem;
		width: 100%;
		max-width: 960px;
		max-height: 90vh;
		overflow-y: auto;
		box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4);
	}

	@media (min-width: 1024px) {
		.hb-modal { padding: 4.5rem 3rem 3rem; overflow-y: visible; }
	}

	.hb-close {
		position: absolute;
		top: 1.25rem;
		right: 1.25rem;
		background: none;
		border: none;
		cursor: pointer;
		color: #021300;
		padding: 0.25rem;
		line-height: 0;
		transition: color 0.2s ease;
	}

	.hb-close:hover { color: #0AAD0A; }
	.hb-close svg { color: inherit; }

	.hb-modal-inner {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	@media (min-width: 1024px) {
		.hb-modal-inner { flex-direction: row; align-items: flex-end; }
	}

	/* ─── Video iframe ───────────────────────────── */
	.hb-video-wrap {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		background-color: #000;
		border-radius: 12px;
		overflow: hidden;
		flex-shrink: 0;
	}

	@media (min-width: 1024px) { .hb-video-wrap { width: 65%; } }

	.hb-video-border {
		position: absolute;
		inset: 0;
		border: 2px solid #021300;
		border-radius: 12px;
		pointer-events: none;
		z-index: 10;
	}

	.hb-video-wrap iframe {
		width: 100%;
		height: 100%;
		border: none;
	}

	/* ─── Modal side content ─────────────────────── */
	.hb-modal-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	@media (min-width: 1024px) { .hb-modal-content { width: 35%; } }

	.hb-modal-heading {
		color: #021300;
		font-size: 1.75rem;
		font-weight: 700;
		line-height: 1.2;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 1024px) { .hb-modal-heading { font-size: 2.25rem; } }

	.hb-modal-body {
		color: #021300;
		font-size: 1rem;
		font-weight: 300;
		line-height: 1.625;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.hb-modal-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		text-decoration: none;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
	}

	@media (min-width: 640px) { .hb-modal-btn { width: 150px; } }

	.hb-modal-btn:hover {
		background-color: #0AAD0A;
		text-decoration: none;
		color: #ffffff;
	}
</style>

<script>
	(function () {
		const lightbox  = document.getElementById('hb-lightbox');
		const backdrop  = document.getElementById('hb-backdrop');
		const openBtn   = document.getElementById('hb-open');
		const closeBtn  = document.getElementById('hb-close');
		const iframe    = document.getElementById('hb-iframe') as HTMLIFrameElement | null;

		function openLightbox() {
			if (!lightbox || !iframe) return;
			iframe.src = iframe.dataset.src ?? '';
			lightbox.classList.add('is-open');
			document.body.style.overflow = 'hidden';
		}

		function closeLightbox() {
			if (!lightbox || !iframe) return;
			lightbox.classList.remove('is-open');
			iframe.src = '';
			document.body.style.overflow = '';
		}

		openBtn?.addEventListener('click', openLightbox);
		closeBtn?.addEventListener('click', closeLightbox);
		backdrop?.addEventListener('click', closeLightbox);

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') closeLightbox();
		});
	})();
</script>
