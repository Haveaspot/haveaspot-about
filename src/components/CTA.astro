---
import { Image } from 'astro:assets';
import ctaImg from '../assets/images/HAS-CTA-Image.webp';
---

<section class="cta">
	<div class="cta-container">
		<div class="cta-card">

			<!-- Left: Text + Button -->
			<div class="cta-left">
				<div class="cta-text">
					<h2 class="cta-heading">
						Unlock The Power Of Online Booking For Your Spot
					</h2>
					<p class="cta-body">
						<strong>Want a vibrant, booked-out community space?</strong> Join Haveaspot's free webinar, designed for administrators of village halls, community centres, or any community venue. We'll show you how our platform revolutionises bookings, boosts online visibility, and gives you back valuable time.
					</p>
				</div>

				<div class="cta-actions">
					<a href="/book-a-demo" class="cta-btn">
						Book A Demo
					</a>
				</div>
			</div>

			<!-- Right: Image -->
			<div class="cta-right">
				<div class="cta-image">
					<Image src={ctaImg} alt="Administrator managing bookings on a laptop" />
				</div>
			</div>

		</div>
	</div>
</section>

<style>
	/* ─── Section ─────────────────────────────────── */
	.cta {
		width: 100%;
		padding: 4rem 0;
		background-color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 1024px) { .cta { padding: 6rem 0; } }

	/* ─── Container ──────────────────────────────── */
	.cta-container {
		max-width: 1536px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
	}

	/* ─── Card ───────────────────────────────────── */
	.cta-card {
		border: 2px solid #021300;
		border-radius: 12px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 3rem;
		align-items: center;
	}

	@media (min-width: 768px)  { .cta-card { padding: 3rem; } }
	@media (min-width: 1024px) {
		.cta-card {
			flex-direction: row;
			align-items: stretch;
			padding: 4rem 5rem;
			gap: 5rem;
		}
	}

	/* ─── Left column ────────────────────────────── */
	.cta-left {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	@media (min-width: 1024px) { .cta-left { width: 50%; } }

	.cta-text {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	/* ─── Heading ────────────────────────────────── */
	.cta-heading {
		color: #021300;
		font-size: 2.5rem;
		font-weight: 800;
		line-height: 0.95;
		letter-spacing: -0.02em;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 768px)  { .cta-heading { font-size: 3.5rem; } }
	@media (min-width: 1024px) { .cta-heading { font-size: clamp(3rem, 4.5vw, 4.5rem); } }

	/* ─── Body copy ──────────────────────────────── */
	.cta-body {
		color: #021300;
		font-size: 1rem;
		line-height: 1.625;
		font-weight: 300;
		margin: 0;
		max-width: 36rem;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.cta-body strong { font-weight: 700; color: #021300; }

	/* ─── Button ─────────────────────────────────── */
	.cta-actions { margin-top: auto; }

	.cta-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		text-decoration: none;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
	}

	@media (min-width: 640px) { .cta-btn { width: 150px; } }

	.cta-btn:hover {
		background-color: #0AAD0A;
		text-decoration: none;
		color: #ffffff;
	}

	/* ─── Right column: image ────────────────────── */
	.cta-right {
		width: 100%;
		display: flex;
		flex-direction: column;
	}

	@media (min-width: 1024px) { .cta-right { width: 50%; } }

	.cta-image {
		width: 100%;
		border: 2px solid #021300;
		border-radius: 12px;
		overflow: hidden;
		height: 300px;
	}

	@media (min-width: 768px)  { .cta-image { height: 400px; } }
	@media (min-width: 1024px) { .cta-image { height: 100%; min-height: 400px; } }

	.cta-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}
</style>
