---
import { Image } from 'astro:assets';
import toolsImg from '../assets/images/HAS-Tools-Image1.webp';
---

<section class="tools">
	<div class="tools-container">

		<!-- Section header -->
		<div class="tools-header">
			<h2 class="tools-heading">
				We Give Spots <br class="tools-br-mobile" />All The Tools <br class="tools-br-mid" />They Need To Thrive
			</h2>
			<p class="tools-intro">
				<strong>Our platform makes it easy for spots to thrive.</strong>
				It provides spots with a powerful suite of <strong>free</strong> tools,
				developed entirely around their need:
			</p>
		</div>

		<!-- Content grid -->
		<div class="tools-grid">

			<!-- Left column: feature list card + button -->
			<div class="tools-left">

				<!-- Dark feature list card -->
				<div class="tools-card">

					<div class="tools-item">
						<div class="tools-icon-box">
							<!-- monitor-check -->
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
								<path d="m9 10 2 2 4-4"/>
								<rect width="20" height="14" x="2" y="3" rx="2"/>
								<path d="M12 17v4"/>
								<path d="M8 21h8"/>
							</svg>
						</div>
						<h3 class="tools-item-label">Low Admin</h3>
					</div>

					<div class="tools-item">
						<div class="tools-icon-box">
							<!-- receipt-pound-sterling -->
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
								<path d="M10 17V9.5a1 1 0 0 1 5 0"/>
								<path d="M4 3a1 1 0 0 1 1-1 1.3 1.3 0 0 1 .7.2l.933.6a1.3 1.3 0 0 0 1.4 0l.934-.6a1.3 1.3 0 0 1 1.4 0l.933.6a1.3 1.3 0 0 0 1.4 0l.933-.6a1.3 1.3 0 0 1 1.4 0l.934.6a1.3 1.3 0 0 0 1.4 0l.933-.6A1.3 1.3 0 0 1 19 2a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1 1.3 1.3 0 0 1-.7-.2l-.933-.6a1.3 1.3 0 0 0-1.4 0l-.934.6a1.3 1.3 0 0 1-1.4 0l-.933-.6a1.3 1.3 0 0 0-1.4 0l-.933.6a1.3 1.3 0 0 1-1.4 0l-.934-.6a1.3 1.3 0 0 0-1.4 0l-.933.6a1.3 1.3 0 0 1-.7.2 1 1 0 0 1-1-1z"/>
								<path d="M8 13h5"/>
								<path d="M8 17h7"/>
							</svg>
						</div>
						<h3 class="tools-item-label">No Fees For Spots</h3>
					</div>

					<div class="tools-item">
						<div class="tools-icon-box">
							<!-- smile -->
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"/>
								<path d="M8 14s1.5 2 4 2 4-2 4-2"/>
								<line x1="9" x2="9.01" y1="9" y2="9"/>
								<line x1="15" x2="15.01" y1="9" y2="9"/>
							</svg>
						</div>
						<h3 class="tools-item-label">Better Booking Experiences</h3>
					</div>

				</div>

				<!-- Button -->
				<div class="tools-actions">
					<a href="/for-spots" class="tools-btn">Find Out More</a>
				</div>

			</div>

			<!-- Right column: dashboard image -->
			<div class="tools-image">
				<Image src={toolsImg} alt="Dashboard preview" />
			</div>

		</div>

	</div>
</section>

<style>
	/* ─── Section ─────────────────────────────────── */
	.tools {
		width: 100%;
		padding: 4rem 0;
		background-color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
		overflow: hidden;
	}

	@media (min-width: 1024px) { .tools { padding: 6rem 0; } }

	/* ─── Container — matches header/hero ────────── */
	.tools-container {
		max-width: 1536px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	/* ─── Section header ─────────────────────────── */
	.tools-header {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		width: 100%;
	}

	.tools-heading {
		color: #021300;
		font-size: 2.25rem;
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 0;
		white-space: normal;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 1024px) {
		.tools-heading { white-space: nowrap; }
	}

	/* Heading line breaks */
	.tools-br-mobile { display: block; }
	@media (min-width: 640px) { .tools-br-mobile { display: none; } }

	.tools-br-mid { display: block; }
	@media (min-width: 1024px) { .tools-br-mid { display: none; } }

	.tools-intro {
		color: #021300;
		font-size: 1rem;
		line-height: 1.625;
		font-weight: 300;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	/* ─── Content grid ───────────────────────────── */
	/* Mobile: stacked | Desktop: 2fr / 3fr */
	.tools-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		align-items: stretch;
	}

	@media (min-width: 1024px) {
		.tools-grid {
			grid-template-columns: 2fr 3fr;
		}
	}

	/* ─── Left column ────────────────────────────── */
	.tools-left {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	/* ─── Dark feature card ──────────────────────── */
	.tools-card {
		background-color: #021300;
		border-radius: 12px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 2.5rem;
		flex-grow: 1;
	}

	@media (min-width: 1024px) {
		.tools-card { padding: 3rem; }
	}

	/* ─── Feature items ──────────────────────────── */
	.tools-item {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.tools-icon-box {
		width: 80px;
		height: 80px;
		flex-shrink: 0;
		background-color: #ffffff;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #021300;
	}

	.tools-icon-box svg { color: #021300; }

	.tools-item-label {
		color: #ffffff;
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 640px) {
		.tools-item-label { font-size: 1.5rem; }
	}

	/* ─── Button — matches hero/why buttons ─────── */
	.tools-actions {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	@media (min-width: 640px) { .tools-actions { flex-direction: row; } }

	.tools-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		text-decoration: none;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
	}

	@media (min-width: 640px) { .tools-btn { width: 150px; } }

	.tools-btn:hover {
		background-color: #0AAD0A;
		text-decoration: none;
		color: #ffffff;
	}

	/* ─── Dashboard image ────────────────────────── */
	.tools-image {
		width: 100%;
		border: 2px solid #021300;
		border-radius: 12px;
		overflow: hidden;
		height: 250px;
	}

	@media (min-width: 768px)  { .tools-image { height: 400px; } }
	@media (min-width: 1024px) { .tools-image { height: 500px; } }

	.tools-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}
</style>
