---
const features = [
	{
		icon: "/icons/HomeFeaturesOnline.webp",
		title: "Easily Get Your Spot Online",
		description: "Get Found, Get Booked, Get Going. List Your Spot And Build A Dynamic Online Presence, Website Or No Website.",
		href: "/for-spots",
		buttonLabel: "Find Out More",
	},
	{
		icon: "/icons/HomeFeaturesOneView.webp",
		title: "Manage All Your Bookings In One Place",
		description: "All Bookings, One Dashboard: See Every Reservation, Regardless Of Source, In A Single, Organised View.",
		href: "/for-spots",
		buttonLabel: "Find Out More",
	},
	{
		icon: "/icons/HomeFeaturesSecurePayments.webp",
		title: "Securely Take Payments",
		description: "Smart Payments, Effortless Tracking: Simplify Your Finances With Online Payments, Automatic Deposits, And Clear Income Visualisation.",
		href: "/for-spots",
		buttonLabel: "Find Out More",
	},
	{
		icon: "/icons/HomeFeaturesCommunicate.webp",
		title: "Communicate With Bookers",
		description: "Free Yourself From Repetitive Tasks: Let Automation Handle Communication And Give Your Bookers A Flawless Booking Journey.",
		href: "/for-spots",
		buttonLabel: "Find Out More",
	},
];
---

<section class="features">
	<div class="features-container">
		<div class="features-grid">

			{features.map((feature) => (
				<div class="feature-card">

					<!-- Icon -->
					<div class="feature-content">
						<div class="feature-icon">
							<img src={feature.icon} alt={feature.title} width="100" height="100" />
						</div>

						<!-- Text -->
						<div class="feature-text">
							<h3 class="feature-title">{feature.title}</h3>
							<p class="feature-desc">{feature.description}</p>
						</div>
					</div>

					<!-- Button -->
					<div class="feature-action">
						<a href={feature.href} class="feature-btn">{feature.buttonLabel}</a>
					</div>

				</div>
			))}

		</div>
	</div>
</section>

<style>
	/* ─── Section ─────────────────────────────────── */
	.features {
		width: 100%;
		padding: 0 0 4rem;
		background-color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
		overflow: hidden;
	}

	@media (min-width: 1024px) { .features { padding-bottom: 6rem; } }

	/* ─── Container ──────────────────────────────── */
	.features-container {
		max-width: 1536px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
	}

	/* ─── Grid ───────────────────────────────────── */
	/* 2 col mobile → 2 col tablet → 4 col large desktop */
	.features-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		align-items: stretch;
	}

	@media (min-width: 768px) { .features-grid { gap: 2rem; } }

	@media (min-width: 1230px) {
		.features-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
	}

	/* ─── Card ───────────────────────────────────── */
	.feature-card {
		background-color: #ffffff;
		border: 2px solid #021300;
		border-radius: 12px;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 1rem;
		transition: box-shadow 0.3s ease;
	}

	@media (min-width: 768px) { .feature-card { padding: 2rem; gap: 2rem; } }

	.feature-card:hover {
		box-shadow: 0 10px 30px rgba(2, 19, 0, 0.12);
	}

	/* ─── Content group (icon + text) ───────────── */
	.feature-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.feature-icon {
		width: 60px;
		height: 60px;
		flex-shrink: 0;
	}

	@media (min-width: 768px) { .feature-icon { width: 100px; height: 100px; } }

	.feature-icon img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		border-radius: 0;
	}

	.feature-text {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.feature-title {
		color: #021300;
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.2;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 768px) { .feature-title { font-size: 1.5rem; } }

	.feature-desc {
		color: #021300;
		font-size: 0.875rem;
		font-weight: 400;
		line-height: 1.5;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 768px) { .feature-desc { font-size: 1rem; line-height: 1.625; } }

	/* ─── Button — matches site standard ─────────── */
	.feature-action { padding-top: 1rem; }

	.feature-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		text-decoration: none;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
	}

	.feature-btn:hover {
		background-color: #0AAD0A;
		text-decoration: none;
		color: #ffffff;
	}
</style>
