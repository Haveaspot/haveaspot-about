---
const features = [
	{
		icon: "/icons/BookerFeatureBook.webp",
		title: "Easily Book Your Community Space",
		description: "Find and reserve local venues quickly with our streamlined, hassle-free booking system.",
	},
	{
		icon: "/icons/BookerFeatureEvent.webp",
		title: "Amazing Spots For Every Occasion",
		description: "Discover unique local spaces perfect for meetings, parties, and every gathering in between.",
	},
	{
		icon: "/icons/BookerFeatureValue.webp",
		title: "Great Venues At Great Prices",
		description: "Get more for less by booking high-quality community spots at unbeatable local rates.",
	},
	{
		icon: "/icons/BookerFeatureHassleFree.webp",
		title: "Hassle Free Venue Booking",
		description: "Skip the phone tag. Instantly secure and manage your local bookings with total ease.",
	},
];
---

<section class="bf-section">
	<div class="bf-container">

		<!-- Header -->
		<div class="bf-header">
			<div class="bf-header-text">
				<h2 class="bf-heading">Find and Book Community Venues</h2>
				<p class="bf-body">
					<strong>Haveaspot helps you discover amazing community spaces (spots)</strong> – village halls, community centres, and more – perfect for bringing people together. Nearby, affordable, well-maintained, and ready for your activity. Book yours today!
				</p>
			</div>

			<a href="https://haveaspot.com" class="bf-btn">Book A Spot</a>
		</div>

		<!-- Grid -->
		<div class="bf-grid">
			{features.map((feature) => {
				const words = feature.title.split(' ');
				const bold = words.slice(0, 2).join(' ');
				const regular = words.slice(2).join(' ');
				return (
					<div class="bf-card">
						<div class="bf-icon">
							<img src={feature.icon} alt={feature.title} width="100" height="100" />
						</div>
						<div class="bf-text">
							<h3 class="bf-card-title">
								<strong>{bold}</strong>{regular ? ` ${regular}` : ''}
							</h3>
							<p class="bf-card-body">{feature.description}</p>
						</div>
					</div>
				);
			})}
		</div>

	</div>
</section>

<style>
	/* ─── Section ─────────────────────────────────── */
	.bf-section {
		width: 100%;
		padding: 4rem 0;
		background-color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
		overflow: hidden;
	}

	@media (min-width: 1024px) { .bf-section { padding: 6rem 0; } }

	/* ─── Container ──────────────────────────────── */
	.bf-container {
		max-width: 1536px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	/* ─── Header ─────────────────────────────────── */
	.bf-header {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		align-items: flex-start;
	}

	@media (min-width: 768px) {
		.bf-header {
			flex-direction: row;
			justify-content: space-between;
			align-items: flex-start;
		}
	}

	/* At 4-col breakpoint, mirror the card grid so text aligns to 3rd card's right edge */
	@media (min-width: 1230px) {
		.bf-header {
			display: grid;
			grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: 2rem;
			align-items: start;
		}
	}

	.bf-header-text {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	@media (min-width: 1230px) {
		.bf-header-text { grid-column: 1 / 4; }
	}

	.bf-heading {
		color: #021300;
		font-size: 2rem;
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 1024px) { .bf-heading { font-size: 2.25rem; } }

	.bf-body {
		color: #021300;
		font-size: 1rem;
		font-weight: 400;
		line-height: 1.625;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.bf-body strong { font-weight: 700; }

	/* ─── Button ─────────────────────────────────── */
	.bf-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		text-decoration: none;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
		flex-shrink: 0;
	}

	@media (min-width: 640px)  { .bf-btn { width: 150px; } }
	@media (min-width: 1230px) { .bf-btn { justify-self: end; align-self: start; } }

	.bf-btn:hover {
		background-color: #0AAD0A;
		text-decoration: none;
		color: #ffffff;
	}

	/* ─── Grid ───────────────────────────────────── */
	.bf-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		align-items: stretch;
	}

	@media (min-width: 768px)  { .bf-grid { gap: 2rem; } }
	@media (min-width: 1230px) { .bf-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

	/* ─── Card ───────────────────────────────────── */
	.bf-card {
		background-color: #ffffff;
		border: 2px solid #021300;
		border-radius: 12px;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		transition: box-shadow 0.3s ease;
	}

	@media (min-width: 768px) { .bf-card { padding: 2rem; gap: 1.5rem; } }

	.bf-card:hover { box-shadow: 0 10px 30px rgba(2, 19, 0, 0.12); }

	/* ─── Icon ───────────────────────────────────── */
	.bf-icon {
		width: 60px;
		height: 60px;
		flex-shrink: 0;
	}

	@media (min-width: 768px) { .bf-icon { width: 100px; height: 100px; } }

	.bf-icon img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		border-radius: 0;
	}

	/* ─── Card text ──────────────────────────────── */
	.bf-text {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.bf-card-title {
		color: #021300;
		font-size: 1rem;
		font-weight: 400;
		line-height: 1.2;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 768px) { .bf-card-title { font-size: 1.5rem; } }

	.bf-card-title strong { font-weight: 700; }

	.bf-card-body {
		color: #021300;
		font-size: 0.875rem;
		font-weight: 400;
		line-height: 1.5;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 768px) { .bf-card-body { font-size: 1rem; line-height: 1.625; } }
</style>
