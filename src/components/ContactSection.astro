---

<section class="con-section">
	<div class="con-container">
		<div class="con-layout">

			<!-- ── Left: Info ─────────────────────────────── -->
			<div class="con-left">
				<div class="con-intro">
					<span class="con-eyebrow">Hey There!</span>
					<h1 class="con-heading">Drop us a line</h1>
					<p class="con-body">Got a question or need something? We're here to help! Drop us a line and we'll get back to you as soon as we can.</p>
				</div>

				<div class="con-details-card">
					{details.map((d) => (
						<div class="con-detail">
							<div class="con-detail-icon">
								<Fragment set:html={d.icon} />
							</div>
							<div class="con-detail-text">
								<span class="con-detail-label">{d.label}</span>
								{d.href
									? <a class="con-detail-value con-detail-link" href={d.href}>{d.value}</a>
									: <span class="con-detail-value">{d.value}</span>
								}
							</div>
						</div>
					))}
				</div>
				<div class="con-image">
					<img src="/HAS-Contact-Image.webp" alt="The Haveaspot team" class="con-img" />
				</div>
			</div>

			<!-- ── Right: Form ────────────────────────────── -->
			<div class="con-right">
				<div class="con-form-card">

					<!-- Form -->
					<form class="con-form" id="con-form" novalidate>

						<!-- Honeypot -->
						<div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;opacity:0;height:0;overflow:hidden;pointer-events:none;">
							<label for="con_website">Website</label>
							<input type="text" name="website" id="con_website" tabindex="-1" autocomplete="off" />
						</div>

						<!-- Time trap -->
						<input type="hidden" id="con-load-time" name="load_time" value="0" />

						<!-- Name row -->
						<div class="con-row">
							<div class="con-field">
								<label class="con-label" for="con-forename">Forename</label>
								<input class="con-input" type="text" id="con-forename" name="forename" placeholder="Jane" required />
							</div>
							<div class="con-field">
								<label class="con-label" for="con-surname">Surname</label>
								<input class="con-input" type="text" id="con-surname" name="surname" placeholder="Smith" required />
							</div>
						</div>

						<!-- Email -->
						<div class="con-field">
							<label class="con-label" for="con-email">Email Address</label>
							<input class="con-input" type="email" id="con-email" name="email" placeholder="hello@example.com" required />
						</div>

						<!-- Message -->
						<div class="con-field">
							<label class="con-label" for="con-message">Your Message</label>
							<textarea class="con-input con-textarea" id="con-message" name="message" placeholder="Tell us what's on your mind…" required></textarea>
						</div>

						<!-- CAPTCHA -->
						<div class="con-field">
							<div class="con-captcha-box">
								<div class="con-captcha-header">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
										<path d="M7 11V7a5 5 0 0 1 10 0v4"/>
									</svg>
									<span>Security Check</span>
								</div>
								<p class="con-captcha-question" id="con-captcha-q">Loading…</p>
								<input
									class="con-input con-captcha-input"
									type="text"
									inputmode="numeric"
									id="con-captcha-answer"
									placeholder="Enter your answer"
									autocomplete="off"
								/>
							</div>
						</div>

						<!-- GDPR + Marketing -->
						<div class="con-checks">
							<label class="con-check">
								<input type="checkbox" name="gdprAgreed" required />
								<span>I agree to my personal data being processed by Haveaspot Ltd in order to respond to my enquiry, in accordance with our <a href="/legal/privacy-policy" class="con-link">Privacy Policy</a>. <strong>(Required)</strong></span>
							</label>
							<label class="con-check">
								<input type="checkbox" name="marketingOptIn" />
								<span>I'd like to receive occasional updates and news from Haveaspot. I understand I can unsubscribe at any time. <strong>(Optional)</strong></span>
							</label>
						</div>

						<!-- Error -->
						<div class="con-error-box" id="con-error" hidden>
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
							</svg>
							<span id="con-error-msg"></span>
						</div>

						<!-- Submit -->
						<div class="con-submit-wrap">
							<button type="submit" class="con-btn" id="con-submit">Send Message</button>
						</div>

						<!-- Success state -->
						<div class="con-success" id="con-success" hidden>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" aria-hidden="true"><path d="M320 576C178.6 576 64 461.4 64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576zM438 209.7C427.3 201.9 412.3 204.3 404.5 215L285.1 379.2L233 327.1C223.6 317.7 208.4 317.7 199.1 327.1C189.8 336.5 189.7 351.7 199.1 361L271.1 433C276.1 438 282.9 440.5 289.9 440C296.9 439.5 303.3 435.9 307.4 430.2L443.3 243.2C451.1 232.5 448.7 217.5 438 209.7z"/></svg>
							<span><strong>Message sent!</strong> Thanks for getting in touch — we'll get back to you as soon as we can.</span>
						</div>

					</form>
				</div>
			</div>

		</div>
	</div>
</section>

<style>
	/* ─── Hidden override ────────────────────────── */
	[hidden] { display: none !important; }

	/* ─── Section ─────────────────────────────────── */
	.con-section {
		width: 100%;
		padding: 4rem 0;
		background-color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 1024px) { .con-section { padding: 6rem 0; } }

	/* ─── Container ──────────────────────────────── */
	.con-container {
		max-width: 1536px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
	}

	/* ─── Two-column layout ──────────────────────── */
	.con-layout {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	@media (min-width: 1024px) {
		.con-layout {
			flex-direction: row;
			align-items: stretch;
			gap: 5rem;
		}
	}

	/* ─── Left column ────────────────────────────── */
	.con-left {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	@media (min-width: 1024px) { .con-left { width: 45%; padding-top: 0.5rem; display: flex; flex-direction: column; } }

	/* ─── Intro ──────────────────────────────────── */
	.con-intro {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.con-eyebrow {
		display: inline-block;
		font-size: 0.875rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #021300;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-heading {
		color: #021300;
		font-size: 2.5rem;
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 768px)  { .con-heading { font-size: 3.5rem; } }
	@media (min-width: 1024px) { .con-heading { font-size: clamp(3rem, 4vw, 4rem); } }

	.con-body {
		color: #374151;
		font-size: 1rem;
		font-weight: 400;
		line-height: 1.75;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	/* ─── Details green card ─────────────────────── */
	.con-details-card {
		background-color: #0E491F;
		border-radius: 12px;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
	}

	@media (min-width: 768px) { .con-details-card { padding: 2.5rem; } }

	.con-detail {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.con-detail-icon {
		width: 56px;
		height: 56px;
		flex-shrink: 0;
		border: 2px solid #ffffff;
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.con-detail-text {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.con-detail-label {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #D5FF00;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-detail-value {
		font-size: 0.9375rem;
		font-weight: 700;
		color: #ffffff;
		line-height: 1.4;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-detail-link {
		text-decoration: none;
		color: #ffffff;
		transition: color 0.2s ease;
	}

	.con-detail-link:hover { color: #D5FF00; }

	/* ─── Image container ───────────────────────── */
	.con-image {
		border: 2px solid #021300;
		border-radius: 12px;
		overflow: hidden;
		background-color: #d1d5db;
		height: 240px;
		position: relative;
	}

	@media (min-width: 768px) { .con-image { height: 300px; } }
	@media (min-width: 1024px) { .con-image { height: auto; flex: 1; min-height: 200px; } }

	.con-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		border-radius: 0;
	}

	/* ─── Right column ───────────────────────────── */
	.con-right {
		width: 100%;
	}

	@media (min-width: 1024px) { .con-right { width: 55%; } }

	/* ─── Form card ──────────────────────────────── */
	.con-form-card {
		border: 2px solid #021300;
		border-radius: 12px;
		padding: 2rem;
		box-sizing: border-box;
	}

	@media (min-width: 768px) { .con-form-card { padding: 2.5rem; } }

	/* ─── Success ────────────────────────────────── */
	.con-success {
		display: flex;
		align-items: flex-start;
		gap: 0.625rem;
		background-color: #f0fdf4;
		border: 1px solid #86efac;
		border-radius: 8px;
		padding: 0.75rem 1rem;
		color: #166534;
		font-size: 0.875rem;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-success svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; fill: #16a34a; }

	/* ─── Form ───────────────────────────────────── */
	.con-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	/* ─── Name row ───────────────────────────────── */
	.con-row {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	@media (min-width: 480px) { .con-row { grid-template-columns: 1fr 1fr; } }

	/* ─── Field ──────────────────────────────────── */
	.con-field {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.con-label {
		color: #021300;
		font-size: 0.9375rem;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-input {
		width: 100%;
		height: 52px;
		padding: 0 1.25rem;
		border-radius: 8px;
		border: 1px solid #6B7280;
		background-color: #F9FAFB;
		color: #021300;
		font-size: 0.9375rem;
		font-family: 'Poppins', system-ui, sans-serif;
		box-sizing: border-box;
		outline: none;
		transition: border-color 0.2s ease;
		appearance: none;
	}

	.con-input::placeholder { color: #6B7280; }
	.con-input:focus { border-color: #021300; }

	/* ─── Textarea ───────────────────────────────── */
	.con-textarea {
		height: auto;
		min-height: 140px;
		padding: 0.875rem 1.25rem;
		resize: vertical;
		line-height: 1.625;
	}

	/* ─── CAPTCHA ────────────────────────────────── */
	.con-captcha-box {
		border: 2px solid #021300;
		border-radius: 8px;
		padding: 1rem 1.25rem;
		background-color: #EDF5FF;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.con-captcha-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #021300;
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-captcha-header svg { width: 14px; height: 14px; flex-shrink: 0; }

	.con-captcha-question {
		color: #021300;
		font-size: 1rem;
		font-weight: 600;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-captcha-input { background-color: #ffffff; }

	/* ─── Checkboxes ─────────────────────────────── */
	.con-checks {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.con-check {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		cursor: pointer;
	}

	.con-check input[type="checkbox"] {
		margin-top: 3px;
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		accent-color: #021300;
		cursor: pointer;
	}

	.con-check span {
		color: #374151;
		font-size: 0.875rem;
		line-height: 1.5;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-check strong { color: #021300; }

	.con-link {
		color: #021300;
		font-weight: 700;
		text-decoration: underline;
	}

	.con-link:hover { color: #0AAD0A; }

	/* ─── Error ──────────────────────────────────── */
	.con-error-box {
		display: flex;
		align-items: flex-start;
		gap: 0.625rem;
		background-color: #fef2f2;
		border: 1px solid #fca5a5;
		border-radius: 8px;
		padding: 0.75rem 1rem;
		color: #991b1b;
		font-size: 0.875rem;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.con-error-box svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; }

	/* ─── Submit ─────────────────────────────────── */
	.con-submit-wrap { padding-top: 0.5rem; }

	.con-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 600;
		font-family: 'Poppins', system-ui, sans-serif;
		cursor: pointer;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
	}

	@media (min-width: 640px) { .con-btn { width: 160px; } }

	.con-btn:hover:not(:disabled) { background-color: #0AAD0A; }
	.con-btn:disabled { opacity: 0.6; cursor: not-allowed; }
</style>

<script>
	(function () {
		// Time trap
		const loadTimeEl = document.getElementById('con-load-time') as HTMLInputElement;
		if (loadTimeEl) loadTimeEl.value = String(Date.now());

		// CAPTCHA
		const a = Math.floor(Math.random() * 9) + 1;
		const b = Math.floor(Math.random() * 9) + 1;
		const questionEl = document.getElementById('con-captcha-q');
		if (questionEl) questionEl.textContent = `What is ${a} + ${b}?`;

		// Form
		const form = document.getElementById('con-form') as HTMLFormElement;
		const submitBtn = document.getElementById('con-submit') as HTMLButtonElement;
		const errorBox = document.getElementById('con-error') as HTMLElement;
		const errorMsg = document.getElementById('con-error-msg') as HTMLElement;
		const successEl = document.getElementById('con-success') as HTMLElement;

		function showError(msg: string) {
			errorMsg.textContent = msg;
			errorBox.hidden = false;
			submitBtn.disabled = false;
			submitBtn.textContent = 'Send Message';
		}

		function hideError() {
			errorBox.hidden = true;
			errorMsg.textContent = '';
		}

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			hideError();

			// Validate CAPTCHA
			const answerEl = document.getElementById('con-captcha-answer') as HTMLInputElement;
			const userAnswer = parseInt(answerEl.value.trim(), 10);
			if (isNaN(userAnswer) || userAnswer !== a + b) {
				showError('Incorrect answer to the security check. Please try again.');
				answerEl.value = '';
				return;
			}

			// Validate GDPR
			const gdprEl = form.querySelector('[name="gdprAgreed"]') as HTMLInputElement;
			if (!gdprEl.checked) {
				showError('Please agree to the data processing terms before submitting.');
				return;
			}

			const loadTime = parseInt((document.getElementById('con-load-time') as HTMLInputElement).value, 10);
			const elapsed = Date.now() - loadTime;
			const marketingEl = form.querySelector('[name="marketingOptIn"]') as HTMLInputElement;

			const payload = {
				forename:    (document.getElementById('con-forename') as HTMLInputElement).value.trim(),
				surname:     (document.getElementById('con-surname') as HTMLInputElement).value.trim(),
				email:       (document.getElementById('con-email') as HTMLInputElement).value.trim(),
				message:     (document.getElementById('con-message') as HTMLTextAreaElement).value.trim(),
				marketingOptIn: marketingEl.checked,
				honeypot:    (document.getElementById('con_website') as HTMLInputElement).value,
				elapsed,
				captchaA: a,
				captchaB: b,
				captchaAnswer: userAnswer,
			};

			submitBtn.disabled = true;
			submitBtn.textContent = 'Sending…';

			try {
				const res = await fetch('/api/submit-contact', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				const json = await res.json();

				if (res.ok && json.ok) {
					successEl.hidden = false;
					submitBtn.disabled = true;
					submitBtn.textContent = 'Sent';
				} else {
					showError(json.error ?? 'Something went wrong. Please try again.');
				}
			} catch {
				showError('Network error. Please check your connection and try again.');
			}
		});
	})();
</script>
