---
import { Image } from 'astro:assets';
import whyImg1 from '../assets/images/HAS-Why-Image1.webp';
import whyImg2 from '../assets/images/HAS-Why-Image2.webp';
---

<section class="why">
	<div class="why-container">

		<div class="why-grid">

			<!-- Image 1 — left on desktop, top-left on mobile -->
			<div class="why-image why-image--1">
				<Image src={whyImg1} alt="Community building exterior" loading="eager" />
			</div>

			<!-- Text — centre on desktop, top (full width) on mobile -->
			<div class="why-text">
				<h2 class="why-heading">
					Unlocking The Full Potential Of Our Shared Spaces.
				</h2>

				<div class="why-body">
					<p class="why-p why-p--bold">
						We know the importance of our community spots. We have seen their impact
						first-hand and we know the challenges these spots face in order to keep
						serving their communities.
					</p>
					<p class="why-p why-p--light">
						We believe that in order for these spots to survive and thrive in the
						modern world we need to get people using them. Simply put, these spots
						need to compete as social enterprises.
					</p>
					<p class="why-p why-p--light">
						Haveaspot empowers community spots to become better social enterprises
						so they can thrive in their communities; for the benefit of their
						communities.
					</p>
				</div>

				<div class="why-actions">
					<a href="/for-spots" class="why-btn">Find Out More</a>
				</div>
			</div>

			<!-- Image 2 — right on desktop, top-right on mobile -->
			<div class="why-image why-image--2">
				<Image src={whyImg2} alt="Community interaction" loading="eager" />
			</div>

		</div>

	</div>
</section>

<style>
	/* ─── Section ─────────────────────────────────── */
	.why {
		width: 100%;
		padding: 4rem 0;
		background-color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
		overflow: hidden;
	}

	@media (min-width: 1024px) { .why { padding: 6rem 0; } }

	/* ─── Container — matches header/hero ────────── */
	.why-container {
		max-width: 1536px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
	}

	/* ─── Grid ───────────────────────────────────── */
	/*
	  Mobile/tablet: 2 cols [1fr 40%], text spans full width (row above images)
	  Desktop:       3 cols [40% 1fr 18%], all stretch to same height
	*/
	.why-grid {
		display: grid;
		grid-template-columns: 1fr 40%;
		grid-template-rows: auto auto;
		column-gap: 1rem;
		row-gap: 3rem;
		align-items: start;
	}

	@media (min-width: 768px) {
		.why-grid {
			grid-template-columns: 1fr 300px;
		}
	}

	@media (min-width: 1024px) {
		.why-grid {
			grid-template-columns: 40% 1fr 18%;
			grid-template-rows: 1fr;
			gap: 2rem;
			align-items: stretch;
		}
	}

	/* ─── Text block ─────────────────────────────── */
	.why-text {
		grid-column: 1 / -1; /* full width on mobile/tablet */
		grid-row: 1;
		order: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 2rem;
		padding: 1rem 0;
	}

	@media (min-width: 1024px) {
		.why-text {
			grid-column: 2;
			grid-row: 1;
			order: 2;
		}
	}

	/* ─── Heading ────────────────────────────────── */
	.why-heading {
		color: #021300;
		font-size: 1.875rem;
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 640px) { .why-heading { font-size: 2.25rem; } }

	/* ─── Body copy ──────────────────────────────── */
	.why-body {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		color: #021300;
	}

	.why-p {
		font-size: 1rem;
		line-height: 1.625;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
		color: #021300;
	}

	.why-p--bold  { font-weight: 700; }
	.why-p--light { font-weight: 300; }

	/* ─── Button — matches hero buttons ─────────── */
	.why-actions {
		margin-top: 1rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	@media (min-width: 640px) { .why-actions { flex-direction: row; } }

	.why-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		text-decoration: none;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
	}

	@media (min-width: 640px) { .why-btn { width: 150px; } }

	.why-btn:hover {
		background-color: #0AAD0A;
		text-decoration: none;
		color: #ffffff;
	}

	/* ─── Images ─────────────────────────────────── */
	.why-image {
		border: 2px solid #021300;
		border-radius: 12px;
		overflow: hidden;
		height: 250px;
	}

	@media (min-width: 768px)  { .why-image { height: 400px; } }
	@media (min-width: 1024px) { .why-image { height: auto; } } /* stretch to text height */

	.why-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}

	/* Image 1 — left col on mobile, first col on desktop */
	.why-image--1 {
		grid-column: 1;
		grid-row: 2;
		order: 2;
	}

	@media (min-width: 1024px) {
		.why-image--1 {
			grid-column: 1;
			grid-row: 1;
			order: 1;
		}
	}

	/* Image 2 — right col on mobile, last col on desktop */
	.why-image--2 {
		grid-column: 2;
		grid-row: 2;
		order: 3;
	}

	@media (min-width: 1024px) {
		.why-image--2 {
			grid-column: 3;
			grid-row: 1;
			order: 3;
		}
	}
</style>
