---
---

<section class="es-section">
	<div class="es-container">
		<div class="es-grid">

			<!-- Text (mobile: order 1 | desktop: right column, cols 8-12) -->
			<div class="es-text">
				<div class="es-text-inner">
					<h2 class="es-heading">
						Setting Your Spot Up Is Easy
					</h2>
					<p class="es-body">
						<strong>With Haveaspot, you can easily list your community venue</strong> and start taking bookings in no time. We've already pre-listed the majority of UK community venues, so all you need to do is claim your spot and add a few details. It's that simple!
					</p>
				</div>
				<a href="https://haveaspot.com/users/sign_up" class="es-btn">Claim Your Spot</a>
			</div>

			<!-- Large left image (mobile: order 2 | desktop: cols 1-3) -->
			<div class="es-media es-large">
				<img src="/HAS-EasySetup-Large.webp" alt="Venue manager setting up their listing on a laptop" class="es-panel-img" />
			</div>

			<!-- Stacked images wrapper (mobile: order 3 side-by-side | desktop: cols 4-6) -->
			<div class="es-stacked">
				<div class="es-media es-top">
					<img src="/HAS-EasySetup-Top.webp" alt="Community centre exterior" class="es-panel-img" />
				</div>
				<div class="es-media es-bottom">
					<img src="/HAS-EasySetup-Bottom.webp" alt="Community gathering at a local venue" class="es-panel-img" />
				</div>
			</div>

		</div>
	</div>
</section>

<style>
	/* ─── Section ─────────────────────────────────── */
	.es-section {
		width: 100%;
		padding: 4rem 0;
		background-color: #ffffff;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 1024px) { .es-section { padding: 6rem 0; } }

	/* ─── Container ──────────────────────────────── */
	.es-container {
		max-width: 1536px;
		margin: 0 auto;
		padding: 0 1rem;
		box-sizing: border-box;
	}

	/* ─── Grid ───────────────────────────────────── */
	/*
	  Mobile:  1 col — text(1), large(2), stacked side-by-side(3)
	  Tablet:  2 cols — text spans 2 (top), large | stacked below
	  Desktop: 12 cols — large(1-3) | stacked(4-6) | gap | text(8-12)
	*/
	.es-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		align-items: stretch;
	}

	@media (min-width: 768px) {
		.es-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.es-grid {
			grid-template-columns: repeat(12, minmax(0, 1fr));
			gap: 2rem;
		}
	}

	/* ─── Text block ─────────────────────────────── */
	.es-text {
		order: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 2rem;
	}

	@media (min-width: 768px) { .es-text { grid-column: 1 / -1; } }

	@media (min-width: 1024px) {
		.es-text {
			grid-column: 8 / 13;
			grid-row: 1;
			order: unset;
			padding-left: 2rem;
		}
	}

	.es-text-inner {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.es-heading {
		color: #021300;
		font-size: 2rem;
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.02em;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	@media (min-width: 1024px) { .es-heading { font-size: 2.25rem; } }

	.es-body {
		color: #021300;
		font-size: 1rem;
		font-weight: 400;
		line-height: 1.625;
		margin: 0;
		font-family: 'Poppins', system-ui, sans-serif;
	}

	.es-body strong { font-weight: 700; }

	/* ─── Button ─────────────────────────────────── */
	.es-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background-color: #021300;
		color: #ffffff;
		text-decoration: none;
		border: none;
		border-radius: 6px;
		height: 44px;
		width: 100%;
		font-size: 16px;
		font-weight: 500;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: background-color 0.2s ease;
		box-sizing: border-box;
	}

	@media (min-width: 640px) { .es-btn { width: 150px; } }

	.es-btn:hover {
		background-color: #0AAD0A;
		text-decoration: none;
		color: #ffffff;
	}

	/* ─── Media panels ───────────────────────────── */
	.es-media {
		border: 2px solid #021300;
		border-radius: 12px;
		overflow: hidden;
		position: relative;
		background-color: #e5e7eb;
	}

	.es-placeholder {
		position: absolute;
		inset: 0;
		background-color: #d1d5db;
	}

	.es-panel-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}

	/* ─── Large left image ───────────────────────── */
	.es-large {
		order: 2;
		height: 300px;
	}

	@media (min-width: 768px) { .es-large { height: 500px; } }

	@media (min-width: 1024px) {
		.es-large {
			grid-column: 1 / 4;
			grid-row: 1;
			order: unset;
			height: auto;
			min-height: 500px;
		}
	}

	/* ─── Stacked images wrapper ─────────────────── */
	.es-stacked {
		order: 3;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	@media (min-width: 768px) {
		.es-stacked {
			display: flex;
			flex-direction: column;
			gap: 2rem;
		}
	}

	@media (min-width: 1024px) {
		.es-stacked {
			grid-column: 4 / 7;
			grid-row: 1;
			order: unset;
			display: flex;
			flex-direction: column;
			gap: 2rem;
		}
	}

	/* Top and bottom stacked images */
	.es-top,
	.es-bottom {
		height: 200px;
	}

	@media (min-width: 768px) {
		.es-top,
		.es-bottom { height: auto; flex: 1; }
	}
</style>
